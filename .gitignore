# Configure-time-generated host-port stub catch-all
# (regenerated by `tools/port/gen_host_assets.py gen-offsets-stub` from
# the CMake configure step into ${CMAKE_BINARY_DIR}/generated/; the
# legacy in-tree path is also covered so a stale local copy from before
# this was made configure-time-generated does not get re-committed).
