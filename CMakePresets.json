{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "sdl-debug",
            "displayName": "SDL port (Debug)",
            "description": "Linux/macOS Debug build of the SDL port.",
            "binaryDir": "${sourceDir}/build/sdl-debug",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "TMC_PORT_PLATFORM": "sdl",
                "TMC_GAME_VERSION": "USA"
            }
        },
        {
            "name": "sdl-release",
            "displayName": "SDL port (Release)",
            "description": "Linux/macOS Release build of the SDL port.",
            "binaryDir": "${sourceDir}/build/sdl-release",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "TMC_PORT_PLATFORM": "sdl",
                "TMC_GAME_VERSION": "USA"
            }
        },
        {
            "name": "sdl-debug-baserom",
            "inherits": "sdl-debug",
            "displayName": "SDL port (Debug + ROM assets)",
            "description": "Debug build with TMC_BASEROM from the TMC_BASEROM environment variable (absolute path to a 16 MiB baserom.gba). See INSTALL_SDL.md.",
            "binaryDir": "${sourceDir}/build/sdl-debug-baserom",
            "cacheVariables": {
                "TMC_BASEROM": "$env{TMC_BASEROM}"
            }
        },
        {
            "name": "sdl-release-baserom",
            "inherits": "sdl-release",
            "displayName": "SDL port (Release + ROM assets)",
            "description": "Release build with TMC_BASEROM from the TMC_BASEROM environment variable (absolute path to a 16 MiB baserom.gba). See INSTALL_SDL.md.",
            "binaryDir": "${sourceDir}/build/sdl-release-baserom",
            "cacheVariables": {
                "TMC_BASEROM": "$env{TMC_BASEROM}"
            }
        }
    ],
    "buildPresets": [
        { "name": "sdl-debug",   "configurePreset": "sdl-debug" },
        { "name": "sdl-release", "configurePreset": "sdl-release" },
        { "name": "sdl-debug-baserom",   "configurePreset": "sdl-debug-baserom" },
        { "name": "sdl-release-baserom", "configurePreset": "sdl-release-baserom" }
    ]
}
